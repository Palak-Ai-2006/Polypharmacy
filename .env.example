# PolyPGx Environment Variables
# Copy this to .env.local and fill in your keys

# === REQUIRED ===
# LLM Provider (pick one)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# OpenAI Embeddings (for ChromaDB ingestion)
OPENAI_API_KEY=sk-your-key-here

# === OPTIONAL (all free, no key needed) ===
# These APIs are free and keyless — URLs are hardcoded in lib/
# RxNorm:  https://rxnav.nlm.nih.gov/REST/
# OpenFDA: https://api.fda.gov/drug/label.json
