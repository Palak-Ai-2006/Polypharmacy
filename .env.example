# PolyPGx Environment Variables
# Copy this to .env.local and fill in your keys

# === REQUIRED ===
# Google Gemini key (required for LLM analysis + PDF report parsing)
GEMINI_API_KEY=your-gemini-api-key-here

# === OPTIONAL ===
# Self-hosted/hosted ChromaDB endpoint for RAG retrieval.
# Leave blank to disable URL-based Chroma.
# CHROMA_URL=http://localhost:8000

# Chroma Cloud (recommended for Vercel production RAG)
# CHROMA_API_KEY=your-chroma-cloud-api-key
# CHROMA_TENANT=your-tenant-id
# CHROMA_DATABASE=your-database-name
